# atom — provider API keys. Copy to `.env` and fill in the keys you have.
# The harness loads this via python-dotenv. Only the key(s) for the model(s)
# you actually run are required.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Alibaba Qwen / DashScope (international endpoint by default)
DASHSCOPE_API_KEY=

# Optional: override the atom home directory (default: ~/.atom)
# ATOM_HOME=

# Optional: LangSmith tracing for workflow runs. Required only when observability.enabled
# (or LANGSMITH_TRACING) is on. Env vars take precedence over the observability: config block.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=atom-workflows

# LangFuse (alternative to LangSmith; set observability.provider: langfuse)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
